[Unit]
Description=Inverter Serial Reader
After=network.target
Wants=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__HOME__/inverter-monitoring
ExecStart=/usr/bin/python3 __HOME__/inverter-monitoring/reader.py
Restart=on-failure
RestartSec=10
StandardOutput=append:__HOME__/inverter-monitoring/reader.log
StandardError=append:__HOME__/inverter-monitoring/reader.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
